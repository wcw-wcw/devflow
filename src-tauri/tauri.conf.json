{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevFlow",
  "version": "0.1.0",
  "identifier": "com.will.devflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4177"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DevFlow",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:4177 https://api.anthropic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
